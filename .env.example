PORT=8080
NODE_ENV=development
APP_URL=http://localhost:8080
ALLOWED_ORIGINS=

MONGO_URI=mongodb://127.0.0.1:27017/item-builder

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Ship from (California warehouse) — Shippo ---
# Optional: bina key ke server chalega; /shipping/rates tab 503 dega jab call karo ge
SHIPPO_API_TOKEN=
SHIP_FROM_NAME=Warehouse
SHIP_FROM_STREET1=
SHIP_FROM_STREET2=
SHIP_FROM_CITY=
SHIP_FROM_STATE=CA
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=

# Default parcel if product has no weightOz (oz / inches)
DEFAULT_PARCEL_WEIGHT_OZ=16
DEFAULT_PARCEL_LENGTH_IN=10
DEFAULT_PARCEL_WIDTH_IN=8
DEFAULT_PARCEL_HEIGHT_IN=4

# --- Stripe (cards, US bank / ACH, Link, Apple Pay via wallet) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook URL: POST {APP_URL}/api/v1/webhooks/stripe

# --- Sales tax: TaxJar (recommended) or CA-only fallback ---
TAXJAR_API_KEY=
# If TaxJar empty: for California ship-to only, apply this rate (e.g. 0.0875 = 8.75%)
CA_FALLBACK_TAX_RATE=0

# --- QuickBooks Online (Phase 2 — OAuth + SalesReceipt sync) ---
# Optional: sirf /integrations/quickbooks/status — keys ke bina bhi OK
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox
